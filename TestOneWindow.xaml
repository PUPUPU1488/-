<Window x:Class="Экзамен.TestOneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Экзамен"
        mc:Ignorable="d"
        Title="TestOneWindow" Height="450" Width="800">
    <StackPanel>
        <UniformGrid Columns="2">
            <Label Content="Количество чисел для запоминания (5-9):"/>
            <TextBox x:Name="CountInput"/>
        </UniformGrid>
        <Label x:Name="ErrorLabel" Content="" Foreground="Red" FontWeight="Bold" Visibility="Collapsed"/>
        <Button Content="Старт" Click="Start_Click" Height="30"/>
        <Button x:Name="DisplayBlock" Content="-" FontSize="32" Height="80" IsEnabled="False" Background="LightGray"/>
        <Label Content="Введите числа через пробел:"/>
        <TextBox x:Name="AnswerInput" Height="30"/>
        <Button Content="Проверить результат" Click="Check_Click" Height="30"/>
        <Label x:Name="ResultLabel" Content="Результат: " FontSize="14" FontWeight="Bold" Foreground="Blue"/>
        <Button Content="Назад" Click="Back_Click" Height="30" Margin="0,20,0,0"/>
    </StackPanel>
</Window>