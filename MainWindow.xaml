<Window x:Class="Экзамен.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Экзамен"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">
            <Button x:Name="btnOpenTest1" Content="Тест №1" Height="35" Margin="0,5" Click="btnOpenTest1_Click"/>
            <Button x:Name="btnOpenTest2" Content="Тест №2" Height="35" Margin="0,5" Click="btnOpenTest2_Click"/>
            <Button x:Name="btnExitApp" Content="Выйти из программы" Height="35" Margin="0,15" Click="btnExitApp_Click"/>
        </StackPanel>
    </Grid>
</Window>
